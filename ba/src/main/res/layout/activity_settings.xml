<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111827"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:gravity="center"
            android:text="設定"
            android:textColor="#38bdf8"
            android:textSize="30sp"
            android:textStyle="bold" />

        <!-- Server URL -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Server URL "
            android:textColor="#9CA3AF"
            android:textSize="20sp" />

        <EditText
            android:id="@+id/etServerUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:background="#1F2937"
            android:hint="https://..."
            android:inputType="textUri"
            android:padding="12dp"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textColorHint="#4B5563" />

        <!-- Device ID -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Device ID "
            android:textColor="#9CA3AF"
            android:textSize="20sp" />

        <EditText
            android:id="@+id/etDeviceId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:background="#1F2937"
            android:hint="2222222"
            android:inputType="text"
            android:padding="12dp"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textColorHint="#4B5563" />

        <!-- Identification Distance -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"
            android:text="識別距離"
            android:textColor="#9CA3AF"
            android:textSize="20sp" />

        <RadioGroup
            android:id="@+id/rgIdentDistance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <RadioButton
                android:id="@+id/rbDist05"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0.5m"
                android:textColor="#FFFFFF"
                android:buttonTint="#0EA5E9"
                android:textSize="20sp" />

            <RadioButton
                android:id="@+id/rbDist10"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="1m"
                android:textColor="#FFFFFF"
                android:buttonTint="#0EA5E9"
                android:textSize="20sp" />

            <RadioButton
                android:id="@+id/rbDist15"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="1.5m"
                android:textColor="#FFFFFF"
                android:buttonTint="#0EA5E9"
                android:textSize="20sp" />

            <RadioButton
                android:id="@+id/rbDist20"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="2m"
                android:textColor="#FFFFFF"
                android:buttonTint="#0EA5E9"
                android:textSize="20sp" />
        </RadioGroup>

        <!-- Liveness Threshold -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="なりすまし防止閾値 (Liveness)"
            android:textColor="#9CA3AF"
            android:textSize="20sp" />

        <EditText
            android:id="@+id/etLivenessThreshold"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:background="#1F2937"
            android:hint="88.0"
            android:inputType="numberDecimal"
            android:padding="12dp"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textColorHint="#4B5563" />

        <!-- TopK Setting -->
        <CheckBox
            android:id="@+id/cbUseTopK"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:text="Flow3 (Face+Vein) uses TopK"
            android:textColor="#FFFFFF"
            android:buttonTint="#0EA5E9"
            android:textSize="20sp"/>

        <!-- Save Button -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#0EA5E9"
            android:padding="10dp"
            android:text="保存"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>
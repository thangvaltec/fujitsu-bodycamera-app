<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111827"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:gravity="center"
            android:text="設定"
            android:textColor="#38bdf8"
            android:textSize="30sp"
            android:textStyle="bold" />

        <!-- Server URL -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Server URL "
            android:textColor="#9CA3AF"
            android:textSize="20sp" />

        <EditText
            android:id="@+id/etServerUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:background="#1F2937"
            android:hint="https://..."
            android:inputType="textUri"
            android:padding="12dp"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textColorHint="#4B5563" />

        <!-- Device ID -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Device ID "
            android:textColor="#9CA3AF"
            android:textSize="20sp" />

        <EditText
            android:id="@+id/etDeviceId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:background="#1F2937"
            android:hint="2222222"
            android:inputType="text"
            android:padding="12dp"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textColorHint="#4B5563" />

        <!-- Identification Distance -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"
            android:text="識別距離"
            android:textColor="#9CA3AF"
            android:textSize="20sp" />

        <RadioGroup
            android:id="@+id/rgIdentDistance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <RadioButton
                android:id="@+id/rbDist05"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0.5m"
                android:textColor="#FFFFFF"
                android:buttonTint="#0EA5E9"
                android:textSize="20sp" />

            <RadioButton
                android:id="@+id/rbDist10"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="1m"
                android:textColor="#FFFFFF"
                android:buttonTint="#0EA5E9"
                android:textSize="20sp" />

            <RadioButton
                android:id="@+id/rbDist15"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="1.5m"
                android:textColor="#FFFFFF"
                android:buttonTint="#0EA5E9"
                android:textSize="20sp" />

            <RadioButton
                android:id="@+id/rbDist20"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="2m"
                android:textColor="#FFFFFF"
                android:buttonTint="#0EA5E9"
                android:textSize="20sp" />
        </RadioGroup>

        <!-- 識別レベル (Recognition Level) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"
            android:text="識別レベル（ライブネス判定ON/OFF）"
            android:textColor="#9CA3AF"
            android:textSize="20sp" />

        <RadioGroup
            android:id="@+id/rgLivenessMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <RadioButton
                android:id="@+id/rbLivenessOff"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="写真を判別しない"
                android:textColor="#FFFFFF"
                android:buttonTint="#0EA5E9"
                android:textSize="18sp"
                android:checked="true" />

            <RadioButton
                android:id="@+id/rbLivenessOn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="写真を判別する"
                android:textColor="#FFFFFF"
                android:buttonTint="#0EA5E9"
                android:textSize="18sp" />
        </RadioGroup>

        <!-- Liveness Threshold -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="なりすまし防止閾値 (Liveness)"
            android:textColor="#9CA3AF"
            android:textSize="20sp" />

        <EditText
            android:id="@+id/etLivenessThreshold"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:background="#1F2937"
            android:hint="88.0"
            android:inputType="numberDecimal"
            android:padding="12dp"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textColorHint="#4B5563" />

        <!-- Auto Authentication Method -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="自動認証設定"
            android:textColor="#9CA3AF"
            android:textSize="20sp" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:layout_marginBottom="8dp">

            <RadioButton
                android:id="@+id/rbAutoNone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="8dp"
                android:text="無効"
                android:textColor="#FFFFFF"
                android:buttonTint="#0EA5E9"
                android:textSize="18sp"
                android:checked="true"/>

            <RadioButton
                android:id="@+id/rbAutoFace"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="顔認証"
                android:textColor="#FFFFFF"
                android:buttonTint="#0EA5E9"
                android:textSize="18sp" />

            <RadioButton
                android:id="@+id/rbAutoVein"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:text="静脈認証"
                android:textColor="#FFFFFF"
                android:buttonTint="#0EA5E9"
                android:textSize="18sp" />

            <RadioButton
                android:id="@+id/rbAutoBoth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="顔と静脈認証"
                android:textColor="#FFFFFF"
                android:buttonTint="#0EA5E9"
                android:textSize="18sp" />
        </GridLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="※設定すると認証結果の表示後、自動で次の認証を開始します。変更はメイン画面に戻ってからデバイス設定画面で行ってください。"
            android:textColor="#9CA3AF"
            android:textSize="12sp"
            android:lineSpacingExtra="4dp" />

        <!-- Face Auth Method -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="顔認証方法"
            android:textColor="#9CA3AF"
            android:textSize="20sp" />

        <RadioGroup
            android:id="@+id/rgFaceAuthMethod"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">
            <RadioButton
                android:id="@+id/rbFaceCloud"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="24dp"
                android:text="クラウドサーバ認証"
                android:textColor="#FFFFFF"
                android:buttonTint="#0EA5E9"
                android:textSize="18sp"
                android:checked="true"/>
            <RadioButton
                android:id="@+id/rbFaceLocal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ローカルサーバ認証"
                android:textColor="#FFFFFF"
                android:buttonTint="#0EA5E9"
                android:textSize="18sp" />
        </RadioGroup>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="※ローカルサーバ認証を利用する場合、あらかじめ「顔認証」アプリで顔登録を行う必要があります。"
            android:textColor="#9CA3AF"
            android:textSize="12sp"
            android:lineSpacingExtra="4dp" />

        <!-- Face and Vein Auth Method -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="顔と静脈認証方法"
            android:textColor="#9CA3AF"
            android:textSize="20sp" />

        <RadioGroup
            android:id="@+id/rgFaceVeinAuthMethod"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">
            <RadioButton
                android:id="@+id/rbFaceVeinCloud"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="24dp"
                android:text="クラウドサーバ認証"
                android:textColor="#FFFFFF"
                android:buttonTint="#0EA5E9"
                android:textSize="18sp"
                android:checked="true"/>
            <RadioButton
                android:id="@+id/rbFaceVeinLocal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ローカルサーバ認証"
                android:textColor="#FFFFFF"
                android:buttonTint="#0EA5E9"
                android:textSize="18sp" />
        </RadioGroup>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="※ローカルサーバ認証を利用する場合、あらかじめ「顔認証」アプリで顔登録を行う必要があります。"
            android:textColor="#9CA3AF"
            android:textSize="12sp"
            android:lineSpacingExtra="4dp" />

        <!-- Top-K & Recognition Threshold -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginBottom="32dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Top-Kの人数"
                    android:textColor="#9CA3AF"
                    android:textSize="20sp" />
                <EditText
                    android:id="@+id/etTopK"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#1F2937"
                    android:hint="1"
                    android:inputType="number"
                    android:padding="12dp"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textColorHint="#4B5563" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="認識比較閾値"
                    android:textColor="#9CA3AF"
                    android:textSize="20sp" />
                <EditText
                    android:id="@+id/etRecognitionThreshold"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#1F2937"
                    android:hint="60.0"
                    android:inputType="numberDecimal"
                    android:padding="12dp"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textColorHint="#4B5563" />
            </LinearLayout>

        </LinearLayout>

        <!-- 結果画面表示設定時間 (Auto-Close Delay) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="結果画面表示設定時間(単位：s）"
            android:textColor="#9CA3AF"
            android:textSize="20sp" />

        <EditText
            android:id="@+id/etAutoCloseDelay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:background="#1F2937"
            android:hint="2.0"
            android:inputType="numberDecimal"
            android:padding="12dp"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textColorHint="#4B5563" />

        <!-- メッセージ表示の時間設定 (Transition Delay) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="メッセージ表示の時間設定(単位：s）"
            android:textColor="#9CA3AF"
            android:textSize="20sp" />

        <EditText
            android:id="@+id/etTransitionDelay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:background="#1F2937"
            android:hint="1.0"
            android:inputType="numberDecimal"
            android:padding="12dp"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textColorHint="#4B5563" />

        <!-- Save Button -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#0EA5E9"
            android:padding="10dp"
            android:text="保存"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>